# =========================
# 🧠 APP CONFIG
# =========================
APP_NAME=acc-mngr
ENVIRONMENT=development
APP_PORT=8008

# =========================
# 🔔 WEBHOOKS
# =========================
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# =========================
# 📊 OBSERVABILITY
# =========================
LOG_LEVEL=info

# =========================
# 🗄️ DATABASE (POSTGRES)
# =========================
POSTGRES_DB=acc_mngr_dev
POSTGRES_USER=acc_mngr_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Porta externa (host)
DB_PORT=5435
# Conexão INTERNA (Docker compose)
DB_HOST=db
# URL padrão para Go (driver pgx/libpq)
DATABASE_URL=postgres://acc_mngr_user:CHANGE_ME_STRONG_PASSWORD@db:5432/acc_mngr_dev?sslmode=disable

# =========================
# ⚡ REDIS
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# =========================
# 🔐 JWT CONFIG
# =========================
JWT_SECRET=CHANGE_ME_SUPER_SECRET_KEY
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# =========================
# 🔐 SECURITY
# =========================
BCRYPT_COST=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =========================
# 🌐 FRONTEND (VITE)
# =========================
VITE_BACKEND_URL=http://localhost:8008
VITE_FRONTEND_PORT=3000

# =========================
# 🌍 CORS
# =========================
# =========================
# 🌍 CORS
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =========================
# 🔑 OAUTH (GOOGLE)
# =========================
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URL=http://localhost:8008/auth/oauth/google/callback

# =========================
# 🔑 OAUTH (GITHUB)
# =========================
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_REDIRECT_URL=http://localhost:8008/auth/oauth/github/callback

# =========================
# 📩 EMAIL (RESET PASSWORD)
# =========================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=no-reply@acc-mngr.local

